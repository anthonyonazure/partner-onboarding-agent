# Anthropic
ANTHROPIC_API_KEY=

# LLM model (defaults to Sonnet 4.6 — cheaper than Opus, plenty for this content work)
ONBOARDING_MODEL=claude-sonnet-4-6

# Inherits everything from b2b-agent-toolkit (B2B_*) — see ../b2b-agent-toolkit/.env.example
B2B_USE_MOCKS=true
B2B_PORTAL_BASE_URL=http://localhost:8001

# Optional: Langfuse tracing. Both keys required to enable; otherwise no-op.
# Get keys at https://cloud.langfuse.com (free tier).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
